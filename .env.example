# Nova runtime configuration
# Copy this file to `.env` and fill in local values. `.env` is gitignored.

# --- Chat LLM used by the main Nova conversation ---
MODEL_ID=
API_KEY=
API_BASE=
# GPT-5 family models only support temperature=1. Leave unset to use a model-aware default.
MODEL_TEMPERATURE=

# --- Core runtime tuning ---
TOKEN_THRESHOLD=100000
IDLE_TIMEOUT=60
HEARTBEAT_INTERVAL_SECONDS=1800
MEMORY_CONSOLIDATION_INTERVAL_SECONDS=21600
IDLE_COMPACT_MINUTES=0

# --- Memory backend ---
# mem0: Mem0 is source of truth; MEMORY.md is generated snapshot
NOVA_MEMORY_BACKEND=mem0
NOVA_USER_ID=local-user
NOVA_MEMORY_SEARCH_LIMIT=6
NOVA_MEMORY_SEARCH_TIMEOUT_MS=1200
NOVA_MEMORY_WRITE_MODE=async

# --- Mem0 vector store ---
MEM0_QDRANT_HOST=localhost
MEM0_QDRANT_PORT=6335
MEM0_COLLECTION=nova_memories
MEM0_ENABLE_GRAPH=false
MEM0_SNAPSHOT_LIMIT=80

# --- Mem0 LLM provider ---
# This is separate from the main chat LLM. Mem0 uses it for memory extraction
# and conflict resolution when `infer=True`.
MEM0_LLM_PROVIDER=
MEM0_LLM_MODEL=
MEM0_LLM_API_KEY=
MEM0_LLM_BASE_URL=

# --- Mem0 embedding provider ---
# This must point to an embedding-capable endpoint/model. Do not blindly reuse
# API_BASE if it only supports chat completions.
MEM0_EMBEDDER_PROVIDER=
MEM0_EMBEDDER_MODEL=
MEM0_EMBEDDER_API_KEY=
MEM0_EMBEDDER_BASE_URL=
MEM0_EMBEDDER_DIMS=

# --- Optional integration test gate ---
# Set to 1 only when Qdrant and a working Mem0 LLM/embedder provider are configured.
NOVA_TEST_MEM0=0
